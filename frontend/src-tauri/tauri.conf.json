{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DailyLikeTrees",
  "version": "0.1.0",
  "identifier": "com.dailyliketrees.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DailyLikeTrees · 如树日常",
        "width": 1320,
        "height": 950,
        "minWidth": 960,
        "minHeight": 692,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:8000 http://127.0.0.1:8000 https://api.dailyliketrees.com https://api.open-meteo.com https://geocoding-api.open-meteo.com https://ipapi.co http://ip-api.com; img-src 'self' data: asset: http://localhost:* http://127.0.0.1:* https:; media-src 'self'; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/backend.exe": "./"
    }
  },
  "plugins": {
    "log": {
      "targets": [
        { "target": "stdout", "level": "info" }
      ]
    }
  }
}
