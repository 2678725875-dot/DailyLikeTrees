# ============================================================
# DailyLikeTrees — .gitignore
# ============================================================

# ── Dependencies ──
node_modules/
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ── Build output ──
frontend/dist/
frontend/dist-ssr/
*.local
backend/build/
backend/dist/
backend/*.spec
frontend/src-tauri/binaries/
frontend/src-tauri/target/
frontend/src-tauri/WebView2Fixed/
frontend/android/app/build/
frontend/android/build/
frontend/android/.gradle/
frontend/android/local.properties
frontend/android/app/src/main/assets/public/
frontend/android/*.keystore
frontend/android/keystore.properties

# ── Database & data (may contain user data) ──
*.db
*.sqlite3
*.sqlite

# ── Environment & secrets ──
.env
.env.*
!.env.example
!.env.pwa

# ── IDE & editors ──
.vscode/
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# ── OS generated ──
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Electron ──
electron-app/node_modules/
electron-app/release/
electron-app/dist/

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Claude Code local ──
.claude/settings.local.json

# ── Scratch / personal notes ──
提示词暂存*
主创意文档*
TODO*.md
*.tmp

# ── Portable distribution zip ──
DailyLikeTrees-portable.zip
dist-portable/

# ── Screenshots ──
screenshots/

# ── Claude Code (except checked-in CLAUDE.md) ──
.claude/

# ── Test coverage ──
coverage/
.nyc_output/
htmlcov/
.pytest_cache/

# ── Misc ──
*.bak
*.orig
